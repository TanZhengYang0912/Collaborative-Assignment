# SERVER key — used by Node for Directions + Geocoding API calls.
# Get your key from Google Cloud Console → APIs & Services → Credentials
# Enable: Maps JavaScript API, Geocoding API, Directions API
GOOGLE_API_KEY=your_google_api_key_here

# Supabase — get from Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_secret_key_here

PORT=4000
