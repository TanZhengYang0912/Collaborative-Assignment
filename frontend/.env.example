# Google Maps — browser key for rendering the map
# Get from: Google Cloud Console → APIs & Services → Credentials → Create API Key
# Enable: Maps JavaScript API
VITE_MAPS_BROWSER_KEY=your_google_maps_browser_key_here

# Backend URL — where the Node.js server is running (don't change this)
VITE_API_BASE=http://localhost:4000

# Supabase — get from Supabase Dashboard → Settings → API
# (anon/public key — never put the service key here, this ships to the browser)
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
