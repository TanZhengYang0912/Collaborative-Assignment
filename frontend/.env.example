# BROWSER key — used by React to render the map.
# Get your key from Google Cloud Console → APIs & Services → Credentials
# Enable: Maps JavaScript API, Geocoding API, Directions API
VITE_MAPS_BROWSER_KEY=your_google_api_key_here

# Google Maps Map ID (optional, for Advanced Markers)
VITE_MAP_ID=your_map_id_here

REACT_APP_GOOGLE_MAPS_API_KEY=your_google_api_key_here
REACT_APP_BACKEND_URL=http://localhost:4000

# Supabase — get from Supabase Dashboard → Settings → API
REACT_APP_SUPABASE_URL=https://your-project-id.supabase.co
REACT_APP_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here

VITE_API_BASE=http://localhost:4000
